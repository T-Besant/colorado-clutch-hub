# The live database and its backups — NEVER commit these (they hold your team's
# real data, and committing would overwrite the server copy on deploy).
hub.db
hub.db.*
*.db.bak*

# The session secret — machine-specific, must stay out of source control.
secret_key.txt

# Daily drill-picks history — a local working file the scheduled task rewrites;
# not part of the app and shouldn't be deployed.
daily_picks_history.md

# Python / editor cruft
__pycache__/
*.pyc
~$*
